{
  "name": "mirafood-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "node dist/scripts/seed.js",
    "seed:dev": "tsx src/scripts/seed.ts",
    "seed:users": "node dist/scripts/seed.js --users-only",
    "seed:users:dev": "tsx src/scripts/seed.ts --users-only",
    "import:tfct": "node dist/scripts/import-tfct.js",
    "import:tfct:dev": "tsx src/scripts/import-tfct.ts",
    "email:test": "tsx src/scripts/email-test.ts",
    "migration:run": "tsx node_modules/typeorm/cli.js migration:run -d src/data-source.cli.ts",
    "migration:revert": "tsx node_modules/typeorm/cli.js migration:revert -d src/data-source.cli.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.3",
    "openai": "^4.77.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.10.4",
    "typeorm": "^0.3.20",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.18.1",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
