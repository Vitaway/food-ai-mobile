NODE_ENV=development
PORT=3011

# Local dev only (docker compose.yml). Production uses POSTGRES_PASSWORD / REDIS_PASSWORD — do not set DATABASE_URL or REDIS_URL on VPS.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mirafood
# REDIS_URL=redis://localhost:6380

# Production VPS (required — use hex passwords: openssl rand -hex 24)
# POSTGRES_PASSWORD=
# REDIS_PASSWORD=

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081,https://mirafood.vitaway.org,https://vitaway.nsengi.space

# Optional: Expo push access token (https://expo.dev/accounts/[account]/settings/access-tokens)
EXPO_ACCESS_TOKEN=

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=MiraFood
OPENROUTER_SITE_URL=https://mirafood.vitaway.org
OPENROUTER_IMAGE_DETAIL=high
OPENROUTER_TEMPERATURE=0.05
PLATE_GEOMETRY_DISTANCE_WEIGHT=0.72

AUTO_RUN_MIGRATIONS=true
SEED_COACH_EMAIL=coach@vitaway.org
SEED_COACH_PASSWORD=Test@123
SEED_ADMIN_EMAIL=admin@vitaway.org
SEED_ADMIN_PASSWORD=Test@123

# MiraFood web app (coach/admin dashboard + email links). Production: https://mirafood.vitaway.org
APP_URL=http://localhost:5173

# Mobile deep link scheme for password reset emails (mirafood://auth/reset-password?token=...)
MOBILE_APP_SCHEME=mirafood

# Transactional email (Gmail SMTP — same setup as piko/inzu)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=MiraFood <noreply@vitaway.org>

# Public URL for uploaded avatars (production: https://vitaway.nsengi.space)
# PUBLIC_API_URL=https://vitaway.nsengi.space
