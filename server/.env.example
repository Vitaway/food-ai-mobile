NODE_ENV=development
PORT=3010

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mirafood
REDIS_URL=redis://localhost:6380

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,http://127.0.0.1:8081

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_APP_NAME=MiraFood
OPENROUTER_SITE_URL=https://vitaway.com
OPENROUTER_IMAGE_DETAIL=high
OPENROUTER_TEMPERATURE=0.05
PLATE_GEOMETRY_DISTANCE_WEIGHT=0.72

AUTO_RUN_MIGRATIONS=true
SEED_COACH_EMAIL=coach@vitaway.com
SEED_COACH_PASSWORD=Test@123
SEED_ADMIN_EMAIL=admin@vitaway.com
SEED_ADMIN_PASSWORD=Test@123
