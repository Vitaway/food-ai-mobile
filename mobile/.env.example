# MiraFood API (Node server — /api/v1/*)
# Local simulator: http://127.0.0.1:3011
#
# Physical phone / Expo Go cannot use 127.0.0.1 (that is the phone itself).
# Set EXPO_PUBLIC_DEV_API_HOST to the Mac IP shown by Metro, e.g.:
#   › Metro waiting on exp://172.20.10.6:8081  →  EXPO_PUBLIC_DEV_API_HOST=172.20.10.6
# Phone + Mac must be on the same Wi‑Fi or hotspot. Restart Expo after changing:
#   npx expo start -c
EXPO_PUBLIC_API_URL=http://127.0.0.1:3011
# EXPO_PUBLIC_DEV_API_HOST=172.20.10.6

# Coach/admin web dashboard
EXPO_PUBLIC_WEB_URL=http://localhost:5173

# Production (EAS builds set these in eas.json):
# EXPO_PUBLIC_API_URL=https://vitaway.nsengi.space
# EXPO_PUBLIC_WEB_URL=https://mirafood.vitaway.org
