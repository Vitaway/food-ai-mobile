# MiraFood API (Node server — must expose /api/v1/auth/*)
# Local dev (simulator): http://127.0.0.1:3011
# Local dev (physical device): http://YOUR_LAN_IP:3011
# Production API + web (same origin at mirafood.vitaway.org):
# EXPO_PUBLIC_API_URL=https://mirafood.vitaway.org
# EXPO_PUBLIC_WEB_URL=https://mirafood.vitaway.org
# Local API (port 3011). On a physical phone, the app auto-uses your Mac's LAN IP from Metro.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3011
EXPO_PUBLIC_WEB_URL=http://localhost:5173
