# MiraFood API (Node server — /api/v1/*)
# Local dev (simulator): http://127.0.0.1:3011
# Local dev (physical device / Expo Go): keep 127.0.0.1 — the app swaps in your Mac LAN IP from Metro.
# If auto-detect fails, set your Mac IP explicitly (same IP shown in `npx expo start`):
# EXPO_PUBLIC_DEV_API_HOST=192.168.68.139
EXPO_PUBLIC_API_URL=http://127.0.0.1:3011

# Coach/admin web dashboard (separate host from API in production)
EXPO_PUBLIC_WEB_URL=http://localhost:5173

# Production (EAS builds set these in eas.json):
# EXPO_PUBLIC_API_URL=https://vitaway.nsengi.space
# EXPO_PUBLIC_WEB_URL=https://mirafood.vitaway.org
