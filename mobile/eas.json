{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mirafood.vitaway.org",
        "EXPO_PUBLIC_WEB_URL": "https://mirafood.vitaway.org"
      }
    },
    "apk": {
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mirafood.vitaway.org",
        "EXPO_PUBLIC_WEB_URL": "https://mirafood.vitaway.org",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mirafood.vitaway.org",
        "EXPO_PUBLIC_WEB_URL": "https://mirafood.vitaway.org",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
