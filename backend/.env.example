# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Vision model — must support images. Prefix with provider, e.g. openai/, google/, anthropic/
# gpt-4o-mini is fine for rim detection; diameter is computed server-side.
# For sharper fraction estimates use: openai/gpt-4o
OPENROUTER_MODEL=openai/gpt-4o-mini

# Vision detail: high = sharper plate rim analysis
OPENROUTER_IMAGE_DETAIL=high
OPENROUTER_TEMPERATURE=0.05

# Optional OpenRouter headers (used for rankings on openrouter.ai)
OPENROUTER_APP_NAME=MiraFood
OPENROUTER_SITE_URL=https://vitaway.nsengi.space

PORT=5050
FLASK_DEBUG=false
