{
  "expo": {
    "name": "Vitaway Food AI",
    "slug": "vitaway-food-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vitaway",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vitaway.foodai"
    },
    "android": {
      "package": "com.vitaway.foodai",
      "adaptiveIcon": {
        "backgroundColor": "#168376",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vitaway needs photo access to log meals from your gallery.",
          "cameraPermission": "Vitaway needs camera access to scan and log your meals."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "backgroundColor": "#168376"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
